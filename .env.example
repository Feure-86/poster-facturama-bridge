PORT=3000
PUBLIC_BASE_URL=https://your-backend-domain.com

# Poster
POSTER_CLIENT_ID=your_poster_client_id
POSTER_CLIENT_SECRET=your_poster_client_secret
POSTER_OAUTH_AUTHORIZE_URL=https://joinposter.com/api/auth
POSTER_OAUTH_TOKEN_URL=https://joinposter.com/api/access_token
POSTER_WEBHOOK_SECRET=optional_shared_secret

# Facturama
FACTURAMA_BASE_URL=https://api.facturama.mx
FACTURAMA_USERNAME=your_facturama_username
FACTURAMA_PASSWORD=your_facturama_password
FACTURAMA_API_PATH=/3/cfdis

# Optional defaults
FACTURAMA_SERIE=A
FACTURAMA_CURRENCY=MXN
FACTURAMA_EXPEDITION_PLACE=64000
